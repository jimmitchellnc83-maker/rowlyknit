# Rowly Production Environment Configuration
# Copy this file to .env and fill in your production values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=5000
API_VERSION=v1

# URLs
API_URL=https://api.rowlyknit.com
FRONTEND_URL=https://rowlyknit.com
ALLOWED_ORIGINS=https://rowlyknit.com,https://www.rowlyknit.com,https://api.rowlyknit.com

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rowly_production
DB_USER=rowly_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE
REDIS_DB=0

# ============================================
# SECURITY
# ============================================

# JWT Configuration
JWT_SECRET=CHANGE_ME_32_CHARACTER_RANDOM_STRING_HERE
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_32_CHAR_STRING_HERE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Session Configuration
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_HERE
SESSION_COOKIE_MAX_AGE=604800000
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=strict

# CSRF Configuration
CSRF_SECRET=CHANGE_ME_CSRF_SECRET_HERE
CSRF_COOKIE_SECURE=true

# App URL (used for email verification links, password reset links)
APP_URL=https://rowlyknit.com

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
UPLOAD_RATE_LIMIT_MAX=20

# ============================================
# FILE UPLOAD
# ============================================
UPLOAD_DIR=/home/user/rowlyknit/backend/uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Email Provider: resend (HTTP, preferred) | postmark | sendgrid | ses | noop
# - resend / postmark / sendgrid require EMAIL_API_KEY
# - ses requires AWS_SES_ACCESS_KEY + AWS_SES_SECRET_KEY + AWS_REGION
# - noop is log-only; do NOT use in production without owner sign-off
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=CHANGE_ME_EMAIL_API_KEY_HERE

# Email Addresses
# FROM_EMAIL is the preferred name; EMAIL_FROM is kept as a legacy alias.
FROM_EMAIL=noreply@rowlyknit.com
EMAIL_FROM=noreply@rowlyknit.com
EMAIL_FROM_NAME=Rowly Knitting App
EMAIL_REPLY_TO=support@rowlyknit.com

# SendGrid Configuration (if using SendGrid)
SENDGRID_API_KEY=CHANGE_ME_SENDGRID_API_KEY_HERE

# AWS SES Configuration (if using SES)
AWS_REGION=us-east-1
AWS_SES_ACCESS_KEY=CHANGE_ME_AWS_ACCESS_KEY
AWS_SES_SECRET_KEY=CHANGE_ME_AWS_SECRET_KEY

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=/home/user/rowlyknit/backend/logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ============================================
# CORS
# ============================================
CORS_ORIGIN=https://rowlyknit.com

# ============================================
# SSL/SECURITY
# ============================================
TRUST_PROXY=true
FORCE_HTTPS=true

# Security Headers
HELMET_HSTS_MAX_AGE=31536000
HELMET_HSTS_INCLUDE_SUBDOMAINS=true
HELMET_HSTS_PRELOAD=true

# ============================================
# MONITORING & ANALYTICS
# ============================================

# Error Tracking (Sentry, optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Analytics (optional)
GOOGLE_ANALYTICS_ID=
PLAUSIBLE_DOMAIN=rowlyknit.com

# ============================================
# CLOUDFLARE (Optional CDN)
# ============================================
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_KEY=

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=30

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_SWAGGER=false
ENABLE_METRICS=true
ENABLE_SOCKET_IO=true

# ============================================
# GDPR & COMPLIANCE
# ============================================
DATA_RETENTION_DAYS=365
ENABLE_GDPR_MODE=true

# ============================================
# PERFORMANCE
# ============================================
COMPRESSION_LEVEL=6
CACHE_TTL=3600

# ============================================
# DEVELOPMENT/DEBUG (Set to false in production)
# ============================================
DEBUG=false
VERBOSE_LOGGING=false

# ============================================
# RAVELRY API (Basic Auth - read-only access key for reference data)
# Get your keys at: https://www.ravelry.com/pro/developer
# ============================================
RAVELRY_USERNAME=
RAVELRY_PASSWORD=

# Ravelry OAuth 2.0 (required for yarn/pattern search)
RAVELRY_CLIENT_ID=
RAVELRY_CLIENT_SECRET=
RAVELRY_REDIRECT_URI=https://rowlyknit.com/auth/ravelry/callback

# Token Encryption (64 hex chars = 32-byte key for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
