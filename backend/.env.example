# Application
NODE_ENV=production
PORT=5000
APP_NAME=Rowly
APP_URL=https://rowlyknit.com
API_VERSION=v1

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=rowly_production
DB_USER=rowly_user
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
DB_POOL_MIN=2
DB_POOL_MAX=10
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_MIN_32_CHARS
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# JWT & Authentication
JWT_SECRET=CHANGE_THIS_JWT_SECRET_MINIMUM_32_CHARACTERS
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_MINIMUM_32_CHARACTERS
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CSRF_SECRET=CHANGE_THIS_CSRF_SECRET_MINIMUM_32_CHARACTERS

# Session
SESSION_SECRET=CHANGE_THIS_SESSION_SECRET_MINIMUM_32_CHARACTERS
SESSION_NAME=rowly.sid
SESSION_MAX_AGE=86400000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
UPLOAD_RATE_LIMIT_MAX=20

# File Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_PDF_TYPES=application/pdf

# Transactional email
# EMAIL_PROVIDER picks the adapter:
#   - resend   — HTTP API (preferred for new envs); EMAIL_API_KEY required
#   - postmark — SMTP; EMAIL_API_KEY = server token
#   - sendgrid — SMTP; EMAIL_API_KEY = api key (default for backwards compat)
#   - ses      — SMTP; AWS_SES_ACCESS_KEY + AWS_SES_SECRET_KEY + AWS_REGION
#   - noop     — log-only; intended for tests / unconfigured dev boxes
#
# In dev / test, missing secrets degrade to no-op so unconfigured boxes
# don't try to dial SMTP. In production, missing secrets THROW at startup
# so signup / reset can't silently look successful while no email is
# delivered (PR #379 review finding). To intentionally run production
# without transactional email (e.g. a brief grace period before a
# provider is provisioned), set ALLOW_NOOP_EMAIL_IN_PRODUCTION=true.
# That path is loud-warn-logged and is UNSAFE for launch — knitters who
# sign up or request a reset will not receive email. No-op deliveries
# are recorded in `email_logs` with status='skipped' (not 'sent').
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=CHANGE_THIS_EMAIL_API_KEY
# ALLOW_NOOP_EMAIL_IN_PRODUCTION=true   # UNSAFE — only for explicit, time-boxed grace periods
# FROM_EMAIL is the preferred name; EMAIL_FROM is kept as a legacy alias.
FROM_EMAIL=noreply@rowlyknit.com
EMAIL_FROM=noreply@rowlyknit.com
EMAIL_FROM_NAME=Rowly
EMAIL_REPLY_TO=support@rowlyknit.com
MAIL_SUBDOMAIN=mail.rowlyknit.com

# Security
BCRYPT_ROUNDS=12
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
CORS_ORIGIN=https://rowlyknit.com
ALLOWED_ORIGINS=https://rowlyknit.com,https://www.rowlyknit.com

# Monitoring & Logging
LOG_LEVEL=info
# Sentry — required in production. Get the DSN from your Sentry project's
# settings (Settings → Projects → <project> → Client Keys (DSN)). Without
# this set the backend logs a startup warning and prod errors go untracked.
SENTRY_DSN=
ENABLE_METRICS=true
METRICS_PORT=9090

# Backup & Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 * * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# GDPR & Compliance
DATA_RETENTION_DAYS=730
ENABLE_ANALYTICS=true
ANALYTICS_PROVIDER=plausible
ANALYTICS_DOMAIN=rowlyknit.com

# Feature Flags
ENABLE_CLOUD_SYNC=false
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR=false

# Digital Ocean / Cloud
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=
DO_SPACES_BUCKET=rowly-uploads
DO_SPACES_REGION=nyc3

# Ravelry API (Basic Auth - read-only access key for reference data)
# Get your keys at: https://www.ravelry.com/pro/developer
RAVELRY_USERNAME=
RAVELRY_PASSWORD=

# Ravelry OAuth 2.0 (required for yarn/pattern search)
RAVELRY_CLIENT_ID=
RAVELRY_CLIENT_SECRET=
RAVELRY_REDIRECT_URI=https://rowlyknit.com/auth/ravelry/callback

# Token Encryption (64 hex chars = 32-byte key for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────
# Billing — Lemon Squeezy (Rowly Maker subscription)
# ─────────────────────────────────────────────────────────────────────
# Provider switch. `lemonsqueezy` enables the real adapter; `mock` runs
# an in-process mock for local smoke; unset / `none` disables billing
# entirely (the /upgrade page renders "billing not available yet").
BILLING_PROVIDER=

# Pre-launch escape hatch. When `true`, every authenticated user is
# treated as entitled (canUsePaidWorkspace returns allowed). Use this
# to deploy the billing surface to production BEFORE the owner has
# provisioned Lemon Squeezy, so the gate doesn't lock everyone out.
# Flip to `false` once the trial flow is live.
BILLING_PRE_LAUNCH_OPEN=true

# Owner-email allowlist. Same env var used by `requireOwner` middleware.
# Comma-separated. Owner emails always pass the entitlement gate.
OWNER_EMAIL=

# Lemon Squeezy credentials. Populate ALL of these from the LS
# dashboard before flipping BILLING_PROVIDER=lemonsqueezy.
#   API key:        Settings → API
#   Webhook secret: Settings → Webhooks → "Signing secret"
#   Store id:       Settings → Stores
#   Product id:     Products → Rowly Maker (URL contains the id)
#   Variant ids:    Products → Rowly Maker → variants ("Monthly" + "Annual")
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_PRODUCT_ID=
LEMONSQUEEZY_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_ANNUAL_VARIANT_ID=

# Webhook URL to register in the LS dashboard:
#   https://rowlyknit.com/api/billing/lemonsqueezy/webhook
# Subscribe to: subscription_created, subscription_updated,
# subscription_payment_success, subscription_payment_failed,
# subscription_cancelled, subscription_resumed, subscription_expired
