# Rowly Frontend Production Environment Configuration
# Copy this file to .env.production and fill in your production values

# ============================================
# API CONFIGURATION
# ============================================
VITE_API_URL=https://api.rowlyknit.com
VITE_WS_URL=wss://api.rowlyknit.com

# ============================================
# APPLICATION
# ============================================
VITE_APP_NAME=Rowly
VITE_APP_URL=https://rowlyknit.com
VITE_APP_DESCRIPTION=Your Complete Knitting Project Management App

# ============================================
# FEATURES
# ============================================
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=true

# ============================================
# ANALYTICS (Optional)
# ============================================
VITE_GA_MEASUREMENT_ID=
VITE_PLAUSIBLE_DOMAIN=rowlyknit.com

# ============================================
# CLOUDFLARE (Optional)
# ============================================
VITE_CLOUDFLARE_SITE_KEY=

# ============================================
# SENTRY (Optional - Error Tracking)
# ============================================
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production

# Build-time only — used by @sentry/vite-plugin to upload source maps and
# delete them before deploy. Leave empty to skip upload (build still succeeds).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ============================================
# FILE UPLOAD
# ============================================
VITE_MAX_FILE_SIZE=52428800
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ============================================
# CACHE & STORAGE
# ============================================
VITE_CACHE_VERSION=1.0.0
VITE_INDEXEDDB_NAME=rowly-db
VITE_INDEXEDDB_VERSION=1

# ============================================
# BILLING / ENTITLEMENT (mirror backend OWNER_EMAIL + BILLING_PRE_LAUNCH_OPEN)
# ============================================
# Comma-separated owner email allowlist. Must match backend OWNER_EMAIL
# so the entitlement gate behaves the same on both surfaces. There is
# NO hardcoded fallback in the bundle — leaving this empty means
# nobody hits the owner branch on the frontend.
VITE_OWNER_EMAIL=
# Pre-launch escape hatch. When `true`, every logged-in user is
# treated as entitled by the frontend gate. Must match backend
# BILLING_PRE_LAUNCH_OPEN. Flip both to `false` once trials are live.
VITE_BILLING_PRE_LAUNCH_OPEN=false

# ============================================
# ADSENSE SLOT IDS (per approved tool route)
# ============================================
# Each `<PublicAdSection slot={getAdSlotId('<tool>')}>` reads its slot
# id from the matching VITE_ADSENSE_SLOT_<TOOL> below. Vite bakes these
# values into the JS bundle at BUILD TIME, so:
#
#   1. Set them BEFORE running `npm run build` in `frontend/`.
#   2. Use the SAME numeric ad-unit id you set on the backend in
#      `backend/.env` as `ADSENSE_SLOT_<TOOL>` — the dashboard
#      readiness check fails when the two halves disagree.
#   3. After editing any of these values, REBUILD AND REDEPLOY the
#      frontend image. Editing the .env on the droplet without a
#      rebuild has NO effect — the value the browser ships is already
#      baked into the previous build's JS bundle.
#
# Real ids are 10-digit numerics issued by Google when you create the
# ad unit in the AdSense dashboard. Anything starting with `rowly-` or
# non-numeric is treated as a placeholder and the slot stays empty.
VITE_ADSENSE_SLOT_CALCULATORS_INDEX=
VITE_ADSENSE_SLOT_GAUGE=
VITE_ADSENSE_SLOT_SIZE=
VITE_ADSENSE_SLOT_YARDAGE=
VITE_ADSENSE_SLOT_ROW_REPEAT=
VITE_ADSENSE_SLOT_SHAPING=
VITE_ADSENSE_SLOT_GLOSSARY=
VITE_ADSENSE_SLOT_KNIT911=
