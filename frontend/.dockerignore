# Without this, host `node_modules` is COPY'd into the image and silently
# overwrites the freshly-installed deps from `npm ci`. That bit us during the
# 2026-05-03 audit fix: the host had pdfjs-dist@5.4.394 but the lockfile
# pinned 5.4.296 — the image built clean, then COPY clobbered the worker
# back to 5.4.394 and PDFs failed to render with a version mismatch.
node_modules
.npm

# Build output. The Dockerfile runs `npm run build` itself; don't ship the
# host's stale dist over the top of that.
dist
build

# Local state that has no business in the image.
.env
.env.local
.env.*.local
.cache
.vite
coverage
.eslintcache
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test artifacts.
*.test.ts
*.test.tsx
__tests__
vitest.config.*

# VCS + IDE.
.git
.gitignore
.idea
.vscode

# Capacitor native projects (huge and not used in the web build).
ios
android

# Ad-hoc local files.
.env.production.example
README.md
